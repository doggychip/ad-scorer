# Required: Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model selection
# claude-opus-4-7 = best quality, ~5x cost (use for high-stakes review)
# claude-sonnet-4-6 = default workhorse, balanced
# claude-haiku-4-5-20251001 = fastest/cheapest, lower aesthetic judgment
SCORER_MODEL=claude-sonnet-4-6

# Optional: brand context (auto-injected into the rubric prompt)
BRAND_NAME=Alphawalk.ai
BRAND_TAGLINE=Your AI Investment Assistant
BRAND_COLORS=purple,gold
BRAND_ARCHETYPE=sophisticated, confident, focused — financial product for retail investors

# Optional: storage path
DB_PATH=./data/scores.db

# Optional: multi-shot stability threshold. Batches whose std_total exceeds this
# are flagged "⚠️ unstable" in CLI/report. Default 2.0 (calibrated 2026-05-01 on
# 21-image IB benchmark). Lower = more sensitive (more batches flagged).
STABILITY_STD_THRESHOLD=2.0
